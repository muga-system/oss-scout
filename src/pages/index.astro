---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  ChartColumn,
  CircleQuestionMark,
  Grid2x2,
  ListChecks,
  LogOut,
  Settings,
  Target,
} from "@lucide/astro";
---

<BaseLayout
  title="oss-scout"
  description="Herramienta técnica para evaluar oportunidades de contribución open source."
>
  <div class="grid h-[calc(100vh-3rem)] grid-cols-[4.5rem_1fr] overflow-hidden">
    <aside
      class="flex min-h-0 flex-col border-r border-slate-800 bg-[#02070d]/80"
    >
      <nav class="flex flex-1 flex-col">
        <a
          href="/"
          aria-label="Vista general"
          class="grid h-16 place-items-center border-b border-slate-800 text-cyan-300"
        >
          <Grid2x2 size={22} stroke-width={1.75} />
        </a>

        <a
          href="/evaluate"
          aria-label="Evaluación"
          class="grid h-16 place-items-center border-b border-slate-800 text-slate-400 hover:text-cyan-300"
        >
          <ListChecks size={22} stroke-width={1.75} />
        </a>

        <a
          href="/criteria"
          aria-label="Criterios"
          class="grid h-16 place-items-center border-b border-slate-800 text-slate-400 hover:text-cyan-300"
        >
          <Target size={22} stroke-width={1.75} />
        </a>

        <a
          href="/stats"
          aria-label="Estadísticas"
          class="grid h-16 place-items-center border-b border-slate-800 text-slate-400 hover:text-cyan-300"
        >
          <ChartColumn size={22} stroke-width={1.75} />
        </a>

        <a
          href="/settings"
          aria-label="Configuración"
          class="grid h-16 place-items-center border-b border-slate-800 text-slate-400 hover:text-cyan-300"
        >
          <Settings size={22} stroke-width={1.75} />
        </a>
      </nav>

      <div class="border-t border-slate-800">
        <a
          href="/help"
          aria-label="Ayuda"
          class="grid h-14 place-items-center border-b border-slate-800 text-slate-500 hover:text-cyan-300"
        >
          <CircleQuestionMark size={20} stroke-width={1.75} />
        </a>

        <button
          type="button"
          aria-label="Salir"
          class="grid h-14 w-full place-items-center text-slate-500 hover:text-cyan-300"
        >
          <LogOut size={20} stroke-width={1.75} />
        </button>
      </div>
    </aside>

    <section
      class="grid min-h-0 grid-cols-[minmax(0,1.15fr)_minmax(420px,0.85fr)] overflow-hidden"
    >
      <section class="min-h-0 border-r border-slate-800">
        <header
          class="flex h-16 items-center justify-between border-b border-slate-800 px-6 bg-[#02070d8d] backdrop-blur-xs"
        >
          <p
            class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-300"
          >
            Issues
          </p>

          <button
            type="button"
            class="border border-cyan-500/50 px-3 py-1.5 font-mono text-xs text-cyan-300 hover:bg-cyan-500/10"
          >
            Filtros
          </button>
        </header>

        <div class="h-[calc(100%-4rem)] overflow-hidden p-6">
          <div
            class="h-full border border-slate-800 bg-[#02070d]/30 backdrop-blur-xs"
          >
            <div
              class="grid grid-cols-[96px_1fr_180px_120px] border-b border-slate-800 px-4 py-3 font-mono text-xs uppercase tracking-[0.12em] text-slate-500"
            >
              <span>ID</span>
              <span>Título</span>
              <span>Repo</span>
              <span>Estado</span>
            </div>

            <div class="divide-y divide-slate-800">
              <button
                type="button"
                class="grid w-full grid-cols-[96px_1fr_180px_120px] px-4 py-3 text-left text-sm text-slate-300 hover:bg-cyan-500/5"
              >
                <span class="font-mono text-cyan-300">#512</span>
                <span class="truncate"
                  >Clarificar ejemplo de islands con client:visible</span
                >
                <span class="truncate font-mono text-xs text-slate-500"
                  >withastro/docs</span
                >
                <span class="font-mono text-xs text-emerald-300">apto</span>
              </button>

              <button
                type="button"
                class="grid w-full grid-cols-[96px_1fr_180px_120px] px-4 py-3 text-left text-sm text-slate-300 hover:bg-cyan-500/5"
              >
                <span class="font-mono text-cyan-300">#511</span>
                <span class="truncate"
                  >Mejorar mensaje de error en configuración</span
                >
                <span class="truncate font-mono text-xs text-slate-500"
                  >withastro/astro</span
                >
                <span class="font-mono text-xs text-amber-300">revisar</span>
              </button>

              <button
                type="button"
                class="grid w-full grid-cols-[96px_1fr_180px_120px] px-4 py-3 text-left text-sm text-slate-300 hover:bg-cyan-500/5"
              >
                <span class="font-mono text-cyan-300">#510</span>
                <span class="truncate"
                  >Actualizar referencia de integración Tailwind</span
                >
                <span class="truncate font-mono text-xs text-slate-500"
                  >withastro/docs</span
                >
                <span class="font-mono text-xs text-emerald-300">apto</span>
              </button>

              <button
                type="button"
                class="grid w-full grid-cols-[96px_1fr_180px_120px] px-4 py-3 text-left text-sm text-slate-300 hover:bg-cyan-500/5"
              >
                <span class="font-mono text-cyan-300">#509</span>
                <span class="truncate"
                  >Investigar comportamiento de hidratación parcial</span
                >
                <span class="truncate font-mono text-xs text-slate-500"
                  >withastro/astro</span
                >
                <span class="font-mono text-xs text-rose-300">alto riesgo</span>
              </button>

              <button
                type="button"
                class="grid w-full grid-cols-[96px_1fr_180px_120px] px-4 py-3 text-left text-sm text-slate-300 hover:bg-cyan-500/5"
              >
                <span class="font-mono text-cyan-300">#508</span>
                <span class="truncate"
                  >Agregar captura faltante en guía de despliegue</span
                >
                <span class="truncate font-mono text-xs text-slate-500"
                  >withastro/docs</span
                >
                <span class="font-mono text-xs text-emerald-300">apto</span>
              </button>
            </div>
          </div>
        </div>
      </section>

      <section class="min-h-0">
        <header
          class="flex h-16 items-center justify-between border-b border-slate-800 px-6 bg-[#02070d8d] backdrop-blur-xs"
        >
          <div class="flex items-center gap-3">
            <p
              class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-300"
            >
              Evaluación
            </p>

            <span
              class="border border-slate-800 px-2 py-1 font-mono text-xs text-slate-500"
            >
              sin selección
            </span>
          </div>
        </header>

        <div class="h-[calc(100%-4rem)] overflow-hidden p-6">
          <div
            class="h-full border border-slate-800 bg-[#02070d]/30 backdrop-blur-xs"
          >
            <div class="border-b border-slate-800 px-4 py-3">
              <p
                class="font-mono text-xs uppercase tracking-[0.12em] text-slate-500"
              >
                Checklist
              </p>
            </div>

            <div class="divide-y divide-slate-800">
              <div
                class="grid grid-cols-[1fr_72px_80px] px-4 py-3 font-mono text-xs uppercase tracking-[0.12em] text-slate-500"
              >
                <span>Criterio</span>
                <span>Peso</span>
                <span>Puntaje</span>
              </div>

              <div
                class="grid grid-cols-[1fr_72px_80px] items-center px-4 py-3 text-sm"
              >
                <span class="text-slate-300">Alcance claro</span>
                <span class="font-mono text-xs text-slate-500">20%</span>
                <span class="font-mono text-xs text-cyan-300">4 / 5</span>
              </div>

              <div
                class="grid grid-cols-[1fr_72px_80px] items-center px-4 py-3 text-sm"
              >
                <span class="text-slate-300">Contexto suficiente</span>
                <span class="font-mono text-xs text-slate-500">15%</span>
                <span class="font-mono text-xs text-cyan-300">3 / 5</span>
              </div>

              <div
                class="grid grid-cols-[1fr_72px_80px] items-center px-4 py-3 text-sm"
              >
                <span class="text-slate-300">Complejidad baja</span>
                <span class="font-mono text-xs text-slate-500">20%</span>
                <span class="font-mono text-xs text-cyan-300">4 / 5</span>
              </div>

              <div
                class="grid grid-cols-[1fr_72px_80px] items-center px-4 py-3 text-sm"
              >
                <span class="text-slate-300">No toca core</span>
                <span class="font-mono text-xs text-slate-500">15%</span>
                <span class="font-mono text-xs text-cyan-300">5 / 5</span>
              </div>

              <div
                class="grid grid-cols-[1fr_72px_80px] items-center px-4 py-3 text-sm"
              >
                <span class="text-slate-300">Actividad reciente</span>
                <span class="font-mono text-xs text-slate-500">15%</span>
                <span class="font-mono text-xs text-cyan-300">3 / 5</span>
              </div>

              <div
                class="grid grid-cols-[1fr_72px_80px] items-center px-4 py-3 text-sm"
              >
                <span class="text-slate-300">Buen primer aporte</span>
                <span class="font-mono text-xs text-slate-500">15%</span>
                <span class="font-mono text-xs text-cyan-300">4 / 5</span>
              </div>
            </div>

            <div class="border-t border-slate-800 p-4">
              <div class="grid grid-cols-2 border border-slate-800">
                <div class="border-r border-slate-800 p-4">
                  <p
                    class="font-mono text-xs uppercase tracking-[0.12em] text-slate-500"
                  >
                    Puntaje
                  </p>

                  <p class="mt-3 font-mono text-3xl text-cyan-300">
                    76
                    <span class="text-base text-slate-600">/ 100</span>
                  </p>
                </div>

                <div class="p-4">
                  <p
                    class="font-mono text-xs uppercase tracking-[0.12em] text-slate-500"
                  >
                    Resultado
                  </p>

                  <p class="mt-3 font-mono text-3xl text-emerald-300">Apto</p>
                </div>
              </div>

              <div class="border-x border-b border-slate-800 p-2">
                <p
                  class="font-mono text-xs uppercase tracking-[0.12em] text-slate-500"
                >
                  Nota
                </p>

                <p class="mt-3 text-xs leading-6 text-slate-400">
                  Candidato razonable para una primera contribución. Conviene
                  revisar comentarios recientes antes de tomarlo.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </section>
  </div>
</BaseLayout>
