---
import BaseLayout from "../layouts/BaseLayout.astro";
import EvaluationPanel from "../components/EvaluationPanel.astro";
import IssueTable from "../components/IssueTable.astro";
import WorkspaceLayout from "../components/WorkspaceLayout.astro";
import WorkspacePanel from "../components/WorkspacePanel.astro";
---

<BaseLayout
  title="oss-scout"
  description="Herramienta técnica para evaluar oportunidades de contribución open source."
>
  <WorkspaceLayout>
    <WorkspacePanel title="Issues" withRightBorder>
      <button
        slot="actions"
        type="button"
        class="border border-cyan-500/50 px-3 py-1.5 font-mono text-xs text-cyan-300 hover:bg-cyan-500/10"
      >
        Filtros
      </button>

      <IssueTable />
    </WorkspacePanel>

    <WorkspacePanel title="Evaluación">
      <span
        slot="actions"
        class="border border-slate-800 px-2 py-1 font-mono text-xs text-slate-500"
      >
        sin selección
      </span>

      <EvaluationPanel />
    </WorkspacePanel>
  </WorkspaceLayout>
</BaseLayout>
