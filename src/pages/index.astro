---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  ChartColumn,
  CircleQuestionMark,
  Grid2x2,
  ListChecks,
  LogOut,
  Settings,
  Target,
} from '@lucide/astro';
---

<BaseLayout
  title="oss-scout"
  description="Herramienta técnica para evaluar oportunidades de contribución open source."
>
  <div class="grid h-[calc(100vh-3rem)] grid-cols-[4.5rem_1fr] overflow-hidden">
    <aside class="flex min-h-0 flex-col border-r border-slate-800 bg-[#02070d]/80">
      <nav class="flex flex-1 flex-col">
        <a
          href="/"
          aria-label="Vista general"
          class="grid h-16 place-items-center border-b border-slate-800 text-cyan-300"
        >
          <Grid2x2 size={22} stroke-width={1.75} />
        </a>

        <a
          href="/evaluate"
          aria-label="Evaluación"
          class="grid h-16 place-items-center border-b border-slate-800 text-slate-400 hover:text-cyan-300"
        >
          <ListChecks size={22} stroke-width={1.75} />
        </a>

        <a
          href="/criteria"
          aria-label="Criterios"
          class="grid h-16 place-items-center border-b border-slate-800 text-slate-400 hover:text-cyan-300"
        >
          <Target size={22} stroke-width={1.75} />
        </a>

        <a
          href="/stats"
          aria-label="Estadísticas"
          class="grid h-16 place-items-center border-b border-slate-800 text-slate-400 hover:text-cyan-300"
        >
          <ChartColumn size={22} stroke-width={1.75} />
        </a>

        <a
          href="/settings"
          aria-label="Configuración"
          class="grid h-16 place-items-center border-b border-slate-800 text-slate-400 hover:text-cyan-300"
        >
          <Settings size={22} stroke-width={1.75} />
        </a>
      </nav>

      <div class="border-t border-slate-800">
        <a
          href="/help"
          aria-label="Ayuda"
          class="grid h-14 place-items-center border-b border-slate-800 text-slate-500 hover:text-cyan-300"
        >
          <CircleQuestionMark size={20} stroke-width={1.75} />
        </a>

        <button
          type="button"
          aria-label="Salir"
          class="grid h-14 w-full place-items-center text-slate-500 hover:text-cyan-300"
        >
          <LogOut size={20} stroke-width={1.75} />
        </button>
      </div>
    </aside>

    <section class="grid min-h-0 grid-cols-[minmax(0,1.15fr)_minmax(420px,0.85fr)] overflow-hidden">
      <section class="min-h-0 border-r border-slate-800">
        <header class="flex h-16 items-center justify-between border-b border-slate-800 px-6">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-300">
            Issues
          </p>

          <button
            type="button"
            class="border border-cyan-500/50 px-3 py-1.5 font-mono text-xs text-cyan-300 hover:bg-cyan-500/10"
          >
            Filtros
          </button>
        </header>

        <div class="h-[calc(100%-4rem)] overflow-hidden p-6">
          <div class="h-full border border-slate-800 bg-[#02070d]/70">
            <div class="grid grid-cols-[96px_1fr_180px_120px] border-b border-slate-800 px-4 py-3 font-mono text-xs uppercase tracking-[0.12em] text-slate-500">
              <span>ID</span>
              <span>Título</span>
              <span>Repo</span>
              <span>Estado</span>
            </div>

            <div class="grid h-[calc(100%-2.5rem)] place-items-center px-4 py-12 text-center">
              <div class="max-w-sm">
                <p class="font-mono text-sm text-slate-400">
                  Lista de issues pendiente.
                </p>

                <p class="mt-2 text-sm leading-6 text-slate-600">
                  Acá vamos a construir una tabla estática y después una isla para filtrar o seleccionar.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="min-h-0">
        <header class="flex h-16 items-center justify-between border-b border-slate-800 px-6">
          <div class="flex items-center gap-3">
            <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-300">
              Evaluación
            </p>

            <span class="border border-slate-800 px-2 py-1 font-mono text-xs text-slate-500">
              sin selección
            </span>
          </div>
        </header>

        <div class="h-[calc(100%-4rem)] overflow-hidden p-6">
          <div class="h-full border border-slate-800 bg-[#02070d]/70">
            <div class="border-b border-slate-800 px-4 py-3">
              <p class="font-mono text-xs uppercase tracking-[0.12em] text-slate-500">
                Checklist
              </p>
            </div>

            <div class="grid h-[calc(100%-2.5rem)] place-items-center px-4 py-12 text-center">
              <div class="max-w-sm">
                <p class="font-mono text-sm text-slate-400">
                  Ningún issue seleccionado.
                </p>

                <p class="mt-2 text-sm leading-6 text-slate-600">
                  Este panel va a mostrar criterios, puntaje y resultado de evaluación.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </section>
  </div>
</BaseLayout>