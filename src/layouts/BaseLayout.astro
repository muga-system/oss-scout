---
interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Un pequeño proyecto de Astro para aprender sobre islas mediante la evaluación de problemas de código abierto.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
    </head>

    <body>
        <main class="site-shell">
            <slot />
        </main>
    </body>
</html>

<style is:global>
    :root {
        --background-color: #191717;
        --surface-color: #211f1f;
        --text-color: #f2eeee;
        --text-muted: #b8b1b1;
        --border-soft: rgba(242, 238, 238, 0.16);
        --accent-color: #ff5353;

        font-family:
            Inter,
            ui-sans-serif,
            system-ui,
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            sans-serif;
        color: var(--text-color);
        background: var(--background-color);
    }

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        min-height: 100vh;
        background: var(--background-color);
        color: var(--text-color);
    }

    a {
        color: inherit;
    }

    .site-shell {
        width: min(100%, 1120px);
        margin: 0 auto;
        padding: 64px 24px;
    }

    @media (max-width: 720px) {
        .site-shell {
            padding: 40px 20px;
        }
    }
</style>
