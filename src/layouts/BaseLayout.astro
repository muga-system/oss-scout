---
import "../styles/global.css";
interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Herramienta técnica para evaluar oportunidades de contribución open source.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
    </head>

    <body class="h-screen overflow-hidden bg-[#02070d] text-slate-100 antialiased">
        <div
            class="h-screen overflow-hidden border border-slate-800 bg-[#02070d]"
        >
            <header
                class="flex h-12 items-center justify-between border-b border-slate-800 px-5"
            >
                <div class="flex items-center gap-4">
                    <a
                        href="/"
                        class="font-mono text-lg font-semibold tracking-tight text-slate-100"
                    >
                        oss-scout
                    </a>

                    <div class="hidden h-5 w-px bg-slate-800 md:block"></div>

                    <p
                        class="hidden font-mono text-xs uppercase tracking-[0.18em] text-slate-500 md:block"
                    >
                        workspace
                    </p>
                </div>

                <div class="flex items-center gap-3 font-mono text-xs">
                    <span
                        class="border border-cyan-500/50 px-2 py-1 text-cyan-300"
                    >
                        v0.1
                    </span>

                    <span
                        class="hidden border border-slate-700 px-2 py-1 text-slate-400 sm:inline"
                    >
                        by muga.dev
                    </span>
                </div>
            </header>

            <main
                class="h-[calc(100vh-3rem)] overflow-hidden bg-[#02070d] bg-[radial-gradient(circle_at_1px_1px,rgba(34,211,238,0.18)_1px,transparent_0)] bg-size-[18px_18px]"
            >
                <slot />
            </main>
        </div>
    </body>
</html>
