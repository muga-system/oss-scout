---
const issues = [
  {
    id: '#512',
    title: 'Clarificar ejemplo de islands con client:visible',
    repo: 'withastro/docs',
    status: 'apto',
    statusClass: 'text-emerald-300',
  },
  {
    id: '#511',
    title: 'Mejorar mensaje de error en configuración',
    repo: 'withastro/astro',
    status: 'revisar',
    statusClass: 'text-amber-300',
  },
  {
    id: '#510',
    title: 'Actualizar referencia de integración Tailwind',
    repo: 'withastro/docs',
    status: 'apto',
    statusClass: 'text-emerald-300',
  },
  {
    id: '#509',
    title: 'Investigar comportamiento de hidratación parcial',
    repo: 'withastro/astro',
    status: 'alto riesgo',
    statusClass: 'text-rose-300',
  },
  {
    id: '#508',
    title: 'Agregar captura faltante en guía de despliegue',
    repo: 'withastro/docs',
    status: 'apto',
    statusClass: 'text-emerald-300',
  },
];
---

<div class="h-full border border-slate-800 bg-[#02070d]/30 backdrop-blur-xs">
  <div
    class="grid grid-cols-[96px_1fr_180px_120px] border-b border-slate-800 px-4 py-3 font-mono text-xs uppercase tracking-[0.12em] text-slate-500"
  >
    <span>ID</span>
    <span>Título</span>
    <span>Repo</span>
    <span>Estado</span>
  </div>

  <div class="divide-y divide-slate-800">
    {
      issues.map((issue) => (
        <button
          type="button"
          class="grid w-full grid-cols-[96px_1fr_180px_120px] px-4 py-3 text-left text-sm text-slate-300 hover:bg-cyan-500/5"
        >
          <span class="font-mono text-cyan-300">{issue.id}</span>
          <span class="truncate">{issue.title}</span>
          <span class="truncate font-mono text-xs text-slate-500">{issue.repo}</span>
          <span class={`font-mono text-xs ${issue.statusClass}`}>{issue.status}</span>
        </button>
      ))
    }
  </div>
</div>