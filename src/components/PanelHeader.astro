---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header
  class="flex h-16 items-center justify-between border-b border-slate-800 bg-[#02070d8d] px-6 backdrop-blur-xs"
>
  <p class="font-mono text-xs uppercase tracking-[0.18em] text-cyan-300">
    {title}
  </p>

  <div class="flex items-center gap-3">
    <slot />
  </div>
</header>